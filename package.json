{
  "name": "muazzin",
  "version": "1.0.0",
  "description": "Aplikasi desktop pengingat waktu salat untuk Windows.",
  "author": "yusril dev",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "electron-store": "^8.1.0",
    "node-schedule": "^2.1.1",
    "play-sound": "^1.1.6"
  },
  "build": {
    "appId": "com.muazzin.app",
    "productName": "Mu'azzin",
    "artifactName": "Mu'azzin-Setup-${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ],
            "icon": "assets/icon.ico"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mu'azzin",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
