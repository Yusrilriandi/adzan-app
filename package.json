{
  "name": "muazzin",
  "version": "5.0.1",
  "description": "Aplikasi Desktop Pengingat Waktu Salat untuk Windows.",
  "author": "Yusril Riandi Development",
  "main": "main.js",
  "scripts": {
    "start": "npm run tailwind:build && electron .",
    "tailwind:build": "tailwindcss -i ./renderer/input.css -o ./renderer/tailwind.css",
    "tailwind:watch": "tailwindcss -i ./renderer/input.css -o ./renderer/tailwind.css --watch",
    "build": "npm run tailwind:build && electron-builder",
    "build:win": "npm run tailwind:build && electron-builder --win nsis"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "play-sound": "^1.1.6"
  },
  "build": {
    "appId": "com.muazzin.app",
    "publish": [
      {
        "provider": "github",
        "owner": "Yusrilriandi",
        "repo": "adzan-app"
      }
    ],
    "productName": "Mu'azzin",
    "artifactName": "Muazzin-Setup-${version}.${ext}",
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mu'azzin",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
